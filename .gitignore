# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Yüklənən fayllar (şəxsi müraciət sənədləri)
/public/uploads/

# Yerli test faylları
test-latin*.pdf

# Lokal avtomatik push seçimi (hər developer özündə)
.git-auto-push
.git-commit-msg.tmp
.deploy-lock
.deploy-status.json
/logs/
