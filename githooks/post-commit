#!/bin/sh
# H…ôr commit-d…ôn sonra GitHub-a push (yalnńĪz .git-auto-push faylńĪ varsa)
# Aktiv: npm run git:auto-push:on

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 0

if [ ! -f "$ROOT/.git-auto-push" ]; then
  exit 0
fi

BRANCH="$(git rev-parse --abbrev-ref HEAD)"

echo ""
echo "‚Üí [ostwind] GitHub-a avtomatik push: $BRANCH"

if git push origin "$BRANCH"; then
  echo "‚úď Push tamamlandńĪ."
else
  echo "‚úó Push uńüursuz ‚ÄĒ internet, token v…ô ya conflict yoxlayńĪn."
  exit 0
fi
