# Veritabanı
DATABASE_URL="mysql://kullanici:sifre@localhost:3306/ostwind"

# NextAuth — production için ZORUNLU (en az 32 karakter)
# Oluşturmak için: openssl rand -base64 32
NEXTAUTH_SECRET="buraya-guclu-rastgele-anahtar-yazin"
NEXTAUTH_URL="http://localhost:3000"

# DeepL çeviri (admin panel, isteğe bağlı)
DEEPL_API_KEY=""

# GitHub yeniləmələr (Xeyal → Yeniləmələr) — yalnız production serverdə
DEPLOY_ENABLED="false"
GITHUB_REPO="xeyal9032/ostwind"
DEPLOY_BRANCH="main"
# Özel repo üçün: GITHUB_TOKEN=""
